# MCP Workbench environment template.
# Copy this file to `.env` and replace placeholders with your own values.

# App runtime
MCP_WORKBENCH_APP_NAME=MCP Workbench
MCP_WORKBENCH_ENVIRONMENT=development
MCP_WORKBENCH_DEBUG=false
MCP_WORKBENCH_HOST=127.0.0.1
MCP_WORKBENCH_PORT=8000
MCP_WORKBENCH_LOG_LEVEL=INFO
MCP_WORKBENCH_DATABASE_URL=sqlite:///./data/mcp_workbench.db

# Chat provider
# The app uses an OpenAI-compatible `/chat/completions` API:
#   {LLM_BASE_URL}/chat/completions
LLM_API_KEY=replace-with-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_MODELS='["gpt-4.1-mini", "gpt-4.1", "o4-mini"]'

# Prompt profiles
MCP_WORKBENCH_PROMPT_PROFILES_PATH=app/prompts/profiles.yaml
MCP_WORKBENCH_DEFAULT_PROMPT_PROFILE=default

# MCP
# Set to one of the configured MCP server names to enable it by default.
# Leave empty or unset to start with no MCP server selected.
MCP_WORKBENCH_DEFAULT_MCP_SERVER=

# Alternative provider examples
#
# OpenAI
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4.1-mini
# LLM_MODELS='["gpt-4.1-mini", "gpt-4.1", "o4-mini"]'
#
# Ollama
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1
# LLM_MODELS='["llama3.1", "qwen2.5-coder"]'
#
# LM Studio
# LLM_API_KEY=lm-studio
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=local-model
# LLM_MODELS='["local-model"]'
#
# LocalAI
# LLM_API_KEY=localai
# LLM_BASE_URL=http://localhost:8080/v1
# LLM_MODEL=local-model
# LLM_MODELS='["local-model"]'
